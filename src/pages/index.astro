    <script>
      const nav = document.getElementById("nav");
      const navInner = nav?.querySelector("div");
      window.addEventListener("scroll", () => {
        if (window.scrollY > 50) {
          nav.style.backgroundColor = "rgba(4, 15, 23, 0.95)";
          nav.style.backdropFilter = "blur(12px)";
          nav.style.borderColor = "rgba(12, 46, 62, 0.5)";
          navInner.style.paddingTop = "0.75rem";
          navInner.style.paddingBottom = "0.75rem";
        } else {
          nav.style.backgroundColor = "transparent";
          nav.style.backdropFilter = "none";
          nav.style.borderColor = "transparent";
          navInner.style.paddingTop = "";
          navInner.style.paddingBottom = "";
        }
      });

      const toggle = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");
      const setNavBg = (on, instant = false) => {
        if (instant) {
          nav.style.transition = "none";
          requestAnimationFrame(() => (nav.style.transition = ""));
        }
        if (on || window.scrollY > 50) {
          nav.style.backgroundColor = "rgba(4, 15, 23, 0.95)";
          nav.style.backdropFilter = "blur(12px)";
        } else {
          nav.style.backgroundColor = "";
          nav.style.backdropFilter = "";
        }
      };
      toggle?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
        setNavBg(!menu?.classList.contains("hidden"), true);
      });
      menu?.querySelectorAll("a").forEach((a) =>
        a.addEventListener("click", () => {
          menu?.classList.add("hidden");
          setNavBg(false, true);
        }),
      );

      const reveals = document.querySelectorAll(".reveal");
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("revealed");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
      );
      reveals.forEach((el) => observer.observe(el));
    </script>
